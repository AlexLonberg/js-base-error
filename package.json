{
  "name": "js-base-error",
  "version": "0.6.0",
  "description": "JS Base Error.",
  "author": "Alexander Lonberg <alexlonberg@gmail.com>",
  "homepage": "https://github.com/AlexLonberg/js-base-error",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlexLonberg/js-base-error.git"
  },
  "license": "MIT",
  "keywords": [
    "error"
  ],
  "scripts": {
    "lint": "eslint --config ./eslint.config.js",
    "test": "vitest run --coverage --config vitest.config.ts",
    "bench": "vitest bench --config vitest.config.ts",
    "predist": "npm run lint && vitest run --browser.enabled=false --coverage.enabled=false --config vitest.config.ts && node ./scripts/dist.js",
    "dist": "tsc --project tsconfig.dist.json"
  },
  "type": "module",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@types/node": "^24.5.0",
    "@vitest/browser-playwright": "^4.0.8",
    "@vitest/coverage-istanbul": "^4.0.8",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.39.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.8"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./dev": {
      "import": "./src/dev.ts"
    }
  },
  "main": "./src/index.ts"
}
