{
  // DOC VSCode glob patterns https://code.visualstudio.com/docs/editor/glob-patterns
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true
  },
  "search.exclude": {
    "**/_*": true,
    "**/.git": true,
    "**/node_modules": true,
    ".private/": true,
    ".temp/": true,
    "dist/": true,
    "**/*.json": true,
    "eslint.config.js": true,
    "vitest.config.ts": true,
    "LICENSE.md": true,
    "**/*.png": true
  },
  "googleSearchContextMenu.items": {
    "MDNWeb": {
      "enabled": true
    },
    "NodeJS": {
      "enabled": true
    }
  },
  "eslint.runtime": "node",
  "eslint.useESLintClass": true,
  "eslint.useFlatConfig": true,
  "eslint.codeActionsOnSave.mode": "problems",
  // "eslint.codeActionsOnSave.mode": "all",
  // Отключаем действия для правил удаляющих код при форматировании. Если выше включен mode:"problems" - эта настройка игнорируется.
  // !rule - off
  // *     - on
  "eslint.codeActionsOnSave.rules": [
    "!no-unused-vars",
    "!@typescript-eslint/no-unused-vars",
    "*"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "vitest.shellType": "terminal"
}
